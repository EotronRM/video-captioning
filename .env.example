# OpenAI-compatible endpoint serving a vision-language model.
# The same three variables cover all providers — swapping the brain is config only:
#   OpenRouter:            VLM_BASE_URL=https://openrouter.ai/api/v1
#                          VLM_MODEL=qwen/qwen3-vl-30b-a3b-instruct        <- verify exact id
#   Fireworks:             VLM_BASE_URL=https://api.fireworks.ai/inference/v1
#                          VLM_MODEL=accounts/fireworks/models/<qwen3-vl>  <- verify exact id
#   Self-hosted vLLM (AMD MI300X):
#                          VLM_BASE_URL=http://<your-droplet-ip>:8000/v1
#                          VLM_MODEL=<the --model you served>
VLM_BASE_URL=https://openrouter.ai/api/v1
VLM_API_KEY=sk-your-key-here
VLM_MODEL=qwen/qwen3-vl-30b-a3b-instruct
# Local-run paths (inside Docker these are forced back to /input and /output
# by scripts/run_local.sh, so leaving them set here is safe):
INPUT_PATH=sample_input/tasks.json
OUTPUT_PATH=out/results.json

# Optional: separate (cheaper/fine-tuned) text model for the style stage.
# STYLE_MODEL=

# For reasoning models (e.g. Kimi K2.x on Fireworks): "none" disables thinking
# (faster, cheaper, prevents reasoning text leaking into captions).
# Leave unset for endpoints that reject the parameter.
REASONING_EFFORT=none

# Tuning knobs (defaults shown)
# FRAMES_PER_CLIP=8
# FRAME_WIDTH=512
# MAX_WORKERS=3
# REQUEST_TIMEOUT=25
# TIME_BUDGET_SECONDS=540

# Offline plumbing test: skips ffmpeg/network/API, exercises the full I/O contract.
# VLM_MOCK=1
