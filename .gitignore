# Secrets — the real .env must never enter history (.env.example stays tracked).
# `*.env` catches siblings like quantization.env, which `.env*` does NOT match.
.env
.env.*
*.env
!.env.example

# Scratch credential files (e.g. a token pasted into a file named `HF`)
HF
HF.txt

# Editor
.idea/

# Local run output
out/
distillation-priority-1/checkpoints/

# Quantization artifacts — multi-GB, regenerable from the adapter on HF
quantization-priority-3/merged/
*.gguf

# Personal working notes, not part of the artifact
MI300X-PLAN.md

# Hackathon organizer materials — not ours to redistribute if repo goes public
*.pdf

# Python / uv environment
.venv/
__pycache__/
*.pyc

# Jupyter (for notebook-session work pushed back from the MI300X)
.ipynb_checkpoints/

# macOS noise
.DS_Store
